# Required secrets. Generate independent random values for each setting.
ADMIN_TOKEN=replace-with-at-least-32-random-bytes
PROXY_API_KEY=sk-proxy-replace-with-at-least-24-random-bytes

CONFIG_PATH=/etc/agent-proxy/config.yaml
AGENT_PROXY_DATABASE_PATH=/var/lib/agent-proxy/agent-proxy.db
AGENT_PROXY_HOST=127.0.0.1
AGENT_PROXY_PORT=8300
SHUTDOWN_TIMEOUT_MS=30000

# Include only trusted CLI installation directories.
PATH=/usr/local/bin:/usr/bin:/bin
